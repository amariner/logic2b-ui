---
import { Code } from "astro:components";
import {
  buildAddPrompt,
  buildInitPrompt,
  STACK_LABELS,
  STACKS,
  stackNotes,
} from "@/lib/prompts";
import { DEFAULT_CONFIG, encodePreset } from "@/lib/themes";

interface Props {
  /** Registry item name, e.g. "button" or "theme". */
  name: string;
}

const { name } = Astro.props;

// Read the built registry payload so the Manual tab shows the real source —
// same JSON the CLI installs. Kept in sync automatically at build time.
const payloads = import.meta.glob<Record<string, any>>("../../public/r/*.json", {
  eager: true,
});
const item = payloads[`../../public/r/${name}.json`] as
  | {
      dependencies?: string[];
      registryDependencies?: string[];
      files?: { path: string; content: string }[];
    }
  | undefined;

const deps = item?.dependencies ?? [];
const files = item?.files ?? [];
const cli =
  name === "theme" ? "npx logic2b@latest init" : `npx logic2b@latest add ${name}`;
// The Agent tab: a self-contained prompt to paste into a coding assistant.
const prompt =
  name === "theme"
    ? buildInitPrompt({
        cfg: DEFAULT_CONFIG,
        presetId: encodePreset(DEFAULT_CONFIG),
        mode: "existing",
      })
    : buildAddPrompt(name);
const uid = `install-${name.replace(/[^a-z0-9]/gi, "-")}`;
// Per-stack guidance, composed into the prompt client-side: each note slots
// in right before "## Registry reference" (present in every prompt).
const notesByStack = Object.fromEntries(
  STACKS.filter((s) => s !== "auto").map((s) => [s, stackNotes(s)])
);
---

<div class="install-tabs mt-4" data-uid={uid}>
  <div class="flex items-center gap-1 border-b">
    <button
      class="itab -mb-px border-b-2 border-primary px-3 py-1.5 text-sm font-medium"
      data-tab="cli">CLI</button
    >
    <button
      class="itab -mb-px border-b-2 border-transparent px-3 py-1.5 text-sm font-medium text-muted-foreground"
      data-tab="manual">Manual</button
    >
    <button
      class="itab -mb-px border-b-2 border-transparent px-3 py-1.5 text-sm font-medium text-muted-foreground"
      data-tab="agent">Agent</button
    >
  </div>

  <div class="ipanel-cli pt-4">
    <Code code={cli} lang="bash" theme="github-dark-default" />
  </div>

  <div class="ipanel-agent hidden pt-4">
    <p class="mb-2 text-sm text-muted-foreground">
      Working with an AI assistant? Copy this prompt into Claude Code, Cursor or
      Copilot — it carries the install steps, a no-CLI fallback and a
      verification checklist.
    </p>
    <div class="overflow-hidden rounded-lg border bg-muted/40">
      <div class="flex items-center justify-between gap-2 border-b px-3 py-1.5">
        <div class="stack-pills flex items-center gap-1" role="group" aria-label="Stack">
          {
            STACKS.map((s) => (
              <button
                class={`stack-pill rounded-md px-2 py-0.5 text-xs font-medium transition-colors ${
                  s === "auto"
                    ? "bg-accent text-foreground"
                    : "text-muted-foreground hover:text-foreground"
                }`}
                data-stack={s}
              >
                {STACK_LABELS[s]}
              </button>
            ))
          }
        </div>
        <button
          class="copy-prompt rounded-md border px-2 py-1 text-xs font-medium hover:bg-accent"
          data-prompt={prompt}
        >
          Copy prompt
        </button>
      </div>
      <pre
        class="prompt-body max-h-72 overflow-auto whitespace-pre-wrap px-3 py-2.5 font-mono text-xs leading-relaxed"
        data-base={prompt}>{prompt}</pre>
      <script type="application/json" class="stack-notes" set:html={JSON.stringify(notesByStack)} />
    </div>
  </div>

  <div class="ipanel-manual hidden pt-4">
    {
      deps.length > 0 && (
        <>
          <p class="mb-2 text-sm text-muted-foreground">
            Install the dependencies:
          </p>
          <Code
            code={`npm install ${deps.join(" ")}`}
            lang="bash"
            theme="github-dark-default"
          />
        </>
      )
    }
    {
      files.map((f) => (
        <div class="mt-4">
          <p class="mb-2 text-sm text-muted-foreground">
            Copy into <code class="font-mono text-foreground">{f.path}</code>:
          </p>
          <div class="max-h-[420px] overflow-auto rounded-lg border [&_pre]:m-0 [&_pre]:rounded-none [&_pre]:border-0 [&_pre]:p-4">
            <Code
              code={f.content}
              lang={f.path.endsWith(".css") ? "css" : "tsx"}
              theme="github-dark-default"
            />
          </div>
        </div>
      ))
    }
    {
      files.length === 0 && (
        <p class="text-sm text-muted-foreground">
          This item has no source files to copy — see the CLI tab.
        </p>
      )
    }
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-prompt").forEach((btn) => {
    btn.addEventListener("click", async () => {
      await navigator.clipboard.writeText(btn.dataset.prompt ?? "");
      const original = btn.textContent;
      btn.textContent = "Copied!";
      setTimeout(() => (btn.textContent = original), 1500);
    });
  });

  // Stack pills: recompose the prompt with the chosen stack's notes slotted
  // in before "## Registry reference".
  document.querySelectorAll(".install-tabs").forEach((root) => {
    const pills = root.querySelectorAll<HTMLButtonElement>(".stack-pill");
    if (pills.length === 0) return;
    const pre = root.querySelector<HTMLPreElement>(".prompt-body");
    const copy = root.querySelector<HTMLButtonElement>(".copy-prompt");
    const notesEl = root.querySelector(".stack-notes");
    if (!pre || !copy || !notesEl) return;
    const notes: Record<string, string> = JSON.parse(notesEl.textContent ?? "{}");
    const base = pre.dataset.base ?? "";
    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        pills.forEach((p) => {
          const active = p === pill;
          p.classList.toggle("bg-accent", active);
          p.classList.toggle("text-foreground", active);
          p.classList.toggle("text-muted-foreground", !active);
        });
        const note = notes[pill.dataset.stack ?? ""];
        const next = note
          ? base.replace("## Registry reference", `${note}\n\n## Registry reference`)
          : base;
        pre.textContent = next;
        copy.dataset.prompt = next;
      });
    });
  });

  document.querySelectorAll(".install-tabs").forEach((root) => {
    const tabs = root.querySelectorAll<HTMLButtonElement>(".itab");
    const panels: Record<string, Element | null> = {
      cli: root.querySelector(".ipanel-cli"),
      manual: root.querySelector(".ipanel-manual"),
      agent: root.querySelector(".ipanel-agent"),
    };
    tabs.forEach((btn) => {
      btn.addEventListener("click", () => {
        tabs.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("border-primary", active);
          b.classList.toggle("border-transparent", !active);
          b.classList.toggle("text-muted-foreground", !active);
        });
        Object.entries(panels).forEach(([key, panel]) => {
          panel?.classList.toggle("hidden", key !== btn.dataset.tab);
        });
      });
    });
  });
</script>
