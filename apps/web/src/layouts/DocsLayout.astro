---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { docsNav } from "@/config/docs";
import type { MarkdownHeading } from "astro";

interface Props {
  title: string;
  description?: string;
  headings?: MarkdownHeading[];
}

const { title, description, headings = [] } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={`${title} — logic2b/ui`} description={description}>
  <div class="mx-auto flex max-w-6xl px-4">
    <aside
      class="sticky top-14 hidden h-[calc(100svh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border/40 py-8 pr-4 md:block"
    >
      <nav class="grid gap-6">
        {
          docsNav.map((section) => (
            <div>
              <h4 class="mb-2 text-sm font-semibold">{section.title}</h4>
              <ul class="grid gap-0.5">
                {section.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "block rounded-md px-2 py-1 text-sm transition-colors",
                        currentPath === item.href
                          ? "bg-accent font-medium text-accent-foreground"
                          : "text-muted-foreground hover:text-foreground",
                      ]}
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </aside>

    <main class="min-w-0 flex-1 py-8 md:px-8">
      <div class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
        {description && <p class="mt-2 text-lg text-muted-foreground">{description}</p>}
      </div>
      <article
        class="max-w-none [&_h2]:mt-10 [&_h2]:scroll-mt-20 [&_h2]:border-b [&_h2]:pb-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:scroll-mt-20 [&_h3]:text-xl [&_h3]:font-semibold [&_p]:mt-4 [&_p]:leading-7 [&_a]:font-medium [&_a]:underline [&_a]:underline-offset-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:mt-1 [&_code:not(pre_code)]:rounded [&_code:not(pre_code)]:bg-muted [&_code:not(pre_code)]:px-1.5 [&_code:not(pre_code)]:py-0.5 [&_code:not(pre_code)]:font-mono [&_code:not(pre_code)]:text-sm [&_pre]:mt-4 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:p-4 [&_pre]:text-sm [&_table]:mt-4 [&_table]:w-full [&_th]:border [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_td]:border [&_td]:px-3 [&_td]:py-2"
      >
        <slot />
      </article>
    </main>

    {
      toc.length > 0 && (
        <aside class="sticky top-14 hidden h-[calc(100svh-3.5rem)] w-48 shrink-0 overflow-y-auto py-8 pl-4 xl:block">
          <h4 class="mb-2 text-sm font-medium">On This Page</h4>
          <ul class="grid gap-1 text-sm">
            {toc.map((h) => (
              <li class:list={[h.depth === 3 && "pl-3"]}>
                <a
                  href={`#${h.slug}`}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </div>
</BaseLayout>
