---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { docsNav, componentGroups } from "@/config/docs";
import type { MarkdownHeading } from "astro";

interface Props {
  title: string;
  description?: string;
  headings?: MarkdownHeading[];
}

const { title, description, headings = [] } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const isGroupActive = (group: (typeof componentGroups)[number]) =>
  group.items.some((item) => item.href === currentPath);
---

<BaseLayout title={`${title} — logic2b/ui`} description={description}>
  <div class="flex w-full gap-8 px-6">
    <aside
      class="sticky top-14 hidden h-[calc(100svh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border/40 py-8 pr-4 md:block"
    >
      <nav class="grid gap-6" data-nav-root>
        {
          docsNav.map((section) => (
            <div>
              <h4 class="mb-2 text-sm font-semibold">{section.title}</h4>
              <ul class="grid gap-0.5">
                {section.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "block rounded-md px-2 py-1 text-sm transition-colors",
                        currentPath === item.href
                          ? "bg-accent font-medium text-accent-foreground"
                          : "text-muted-foreground hover:text-foreground",
                      ]}
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
        <div>
          <h4 class="mb-2 text-sm font-semibold">Components</h4>
          <input
            type="text"
            placeholder="Filter components…"
            aria-label="Filter components"
            class="mb-3 w-full rounded-md border border-border/60 bg-transparent px-2 py-1 text-sm outline-none placeholder:text-muted-foreground focus:border-border"
            data-component-filter
          />
          <div class="grid gap-1" data-nav-groups>
            {
              componentGroups.map((group) => (
                <details class="group/nav" data-nav-group open={isGroupActive(group)}>
                  <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1 text-sm font-medium text-foreground/80 hover:text-foreground">
                    {group.title}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="shrink-0 transition-transform group-open/nav:rotate-180"
                      aria-hidden="true"
                    ><path d="m6 9 6 6 6-6" /></svg>
                  </summary>
                  <ul class="grid gap-0.5 py-1 pl-2">
                    {group.items.map((item) => (
                      <li data-nav-item={item.title.toLowerCase()}>
                        <a
                          href={item.href}
                          class:list={[
                            "block rounded-md px-2 py-1 text-sm transition-colors",
                            currentPath === item.href
                              ? "bg-accent font-medium text-accent-foreground"
                              : "text-muted-foreground hover:text-foreground",
                          ]}
                        >
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))
            }
          </div>
        </div>
      </nav>
    </aside>

    <main class="min-w-0 flex-1 py-8">
      <details class="mb-6 rounded-lg border border-border/40 md:hidden">
        <summary
          class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-medium"
        >
          Menu
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
        </summary>
        <nav class="grid gap-6 border-t border-border/40 px-4 py-4" data-nav-root>
          {
            docsNav.map((section) => (
              <div>
                <h4 class="mb-2 text-sm font-semibold">{section.title}</h4>
                <ul class="grid gap-0.5">
                  {section.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          "block rounded-md px-2 py-1 text-sm transition-colors",
                          currentPath === item.href
                            ? "bg-accent font-medium text-accent-foreground"
                            : "text-muted-foreground hover:text-foreground",
                        ]}
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
          <div>
            <h4 class="mb-2 text-sm font-semibold">Components</h4>
            <input
              type="text"
              placeholder="Filter components…"
              aria-label="Filter components"
              class="mb-3 w-full rounded-md border border-border/60 bg-transparent px-2 py-1 text-sm outline-none placeholder:text-muted-foreground focus:border-border"
              data-component-filter
            />
            <div class="grid gap-1" data-nav-groups>
              {
                componentGroups.map((group) => (
                  <details class="group/nav" data-nav-group open={isGroupActive(group)}>
                    <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1 text-sm font-medium text-foreground/80 hover:text-foreground">
                      {group.title}
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="shrink-0 transition-transform group-open/nav:rotate-180"
                        aria-hidden="true"
                      ><path d="m6 9 6 6 6-6" /></svg>
                    </summary>
                    <ul class="grid gap-0.5 py-1 pl-2">
                      {group.items.map((item) => (
                        <li data-nav-item={item.title.toLowerCase()}>
                          <a
                            href={item.href}
                            class:list={[
                              "block rounded-md px-2 py-1 text-sm transition-colors",
                              currentPath === item.href
                                ? "bg-accent font-medium text-accent-foreground"
                                : "text-muted-foreground hover:text-foreground",
                            ]}
                          >
                            {item.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))
              }
            </div>
          </div>
        </nav>
      </details>
      <div class="mb-8 max-w-3xl">
        <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
        {description && <p class="mt-2 text-lg text-muted-foreground">{description}</p>}
      </div>
      <article
        class="max-w-3xl [&_h2]:mt-10 [&_h2]:scroll-mt-20 [&_h2]:border-b [&_h2]:pb-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-8 [&_h3]:scroll-mt-20 [&_h3]:text-xl [&_h3]:font-semibold [&_p]:mt-4 [&_p]:leading-7 [&_a]:font-medium [&_a]:underline [&_a]:underline-offset-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:mt-1 [&_code:not(pre_code)]:rounded [&_code:not(pre_code)]:bg-muted [&_code:not(pre_code)]:px-1.5 [&_code:not(pre_code)]:py-0.5 [&_code:not(pre_code)]:font-mono [&_code:not(pre_code)]:text-sm [&_pre]:mt-4 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:p-4 [&_pre]:text-sm [&_table]:mt-4 [&_table]:w-full [&_th]:border [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_td]:border [&_td]:px-3 [&_td]:py-2"
      >
        <slot />
      </article>
    </main>

    {
      toc.length > 0 && (
        <aside class="sticky top-14 hidden h-[calc(100svh-3.5rem)] w-48 shrink-0 overflow-y-auto py-8 pl-4 xl:block">
          <h4 class="mb-2 text-sm font-medium">On This Page</h4>
          <ul class="grid gap-1 text-sm">
            {toc.map((h) => (
              <li class:list={[h.depth === 3 && "pl-3"]}>
                <a
                  href={`#${h.slug}`}
                  data-toc-link={h.slug}
                  class="toc-link text-muted-foreground transition-colors hover:text-foreground"
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </div>

  <script is:inline>
    // Scrollspy: highlight the TOC link for the heading currently in view.
    (() => {
      const links = Array.from(document.querySelectorAll("[data-toc-link]"));
      if (links.length === 0) return;
      const bySlug = new Map(
        links.map((l) => [l.getAttribute("data-toc-link"), l]),
      );
      const active = "text-foreground font-medium";
      let current = null;
      const setActive = (slug) => {
        if (slug === current) return;
        current = slug;
        for (const l of links)
          l.classList.remove("text-foreground", "font-medium");
        bySlug.get(slug)?.classList.add(...active.split(" "));
      };
      const headings = links
        .map((l) => document.getElementById(l.getAttribute("data-toc-link")))
        .filter(Boolean);
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
      );
      for (const h of headings) observer.observe(h);
    })();
  </script>

  <script is:inline>
    // Components sidebar filter: type to narrow items across every group,
    // auto-expanding matches and restoring each group's original open state
    // (the currently active page's group) once the query is cleared.
    (() => {
      const filters = Array.from(document.querySelectorAll("[data-component-filter]"));
      for (const input of filters) {
        const root = input.closest("[data-nav-root]");
        if (!root) continue;
        const groups = Array.from(root.querySelectorAll("[data-nav-group]"));
        const originalOpen = new Map(groups.map((g) => [g, g.open]));

        input.addEventListener("input", () => {
          const query = input.value.trim().toLowerCase();

          for (const group of groups) {
            const items = Array.from(group.querySelectorAll("[data-nav-item]"));
            let anyVisible = false;
            for (const item of items) {
              const matches =
                query === "" || item.getAttribute("data-nav-item").includes(query);
              item.classList.toggle("hidden", !matches);
              if (matches) anyVisible = true;
            }
            group.classList.toggle("hidden", !anyVisible);
            group.open = query === "" ? originalOpen.get(group) : anyVisible;
          }
        });
      }
    })();
  </script>
</BaseLayout>
