---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildAddPrompt } from "@/lib/prompts";
import registryIndex from "../../../public/r/index.json";

// Charts are registry:block too (they install like blocks) but have their own
// gallery at /charts — keep them off this page.
const blocks = registryIndex.filter(
  (item) =>
    item.type === "registry:block" &&
    !(item as { categories?: string[] }).categories?.includes("charts"),
);
---

<BaseLayout
  title="Blocks — logic2b/ui"
  description="Ready-made page sections and layouts, built from the components."
>
  <div class="mx-auto w-full max-w-screen-2xl px-4 py-10 sm:px-6">
    <div class="mb-10 flex flex-col items-center gap-4 text-center">
      <h1 class="max-w-2xl text-balance text-3xl font-bold tracking-tighter md:text-5xl">
        Building Blocks for the Web
      </h1>
      <p class="max-w-xl text-balance text-muted-foreground md:text-lg">
        Clean, modern building blocks built from the components. Copy and
        paste into your apps. Works with all frameworks. Open Source. Free
        forever.
      </p>
    </div>
    <div class="grid gap-10">
      {
        blocks.map((block) => (
          <div id={block.name} class="scroll-mt-24 overflow-hidden rounded-xl border">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b bg-muted/40 px-4 py-3">
              <div class="min-w-0">
                <h2 class="font-semibold">{block.name}</h2>
                <p class="truncate text-sm text-muted-foreground">
                  {block.description}
                </p>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <div
                  class="viewport-toggle flex items-center gap-0.5 rounded-md border p-0.5"
                  data-target={block.name}
                >
                  <button data-width="100%" class="viewport-btn btn btn-sm h-6 rounded-sm bg-accent px-2">
                    Desktop
                  </button>
                  <button data-width="768px" class="viewport-btn btn btn-sm h-6 rounded-sm px-2">
                    Tablet
                  </button>
                  <button data-width="375px" class="viewport-btn btn btn-sm h-6 rounded-sm px-2">
                    Mobile
                  </button>
                </div>
                <button
                  class="copy-btn btn btn-sm btn-outline font-mono"
                  data-command={`npx logic2b@latest add ${block.name}`}
                  title="Copy install command"
                >
                  npx logic2b add {block.name}
                </button>
                <button
                  class="copy-btn btn btn-sm btn-outline"
                  data-command={buildAddPrompt(block.name)}
                  title="Copy a prompt for your AI assistant"
                >
                  Copy Prompt
                </button>
              </div>
            </div>
            <div class="flex justify-center bg-muted/20 p-4">
              <iframe
                id={`frame-${block.name}`}
                src={`/blocks/preview/${block.name}`}
                class="h-[600px] w-full rounded-lg border bg-background transition-[width] duration-200"
                loading="lazy"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const command = btn.dataset.command;
      if (!command) return;
      await navigator.clipboard.writeText(command);
      const original = btn.textContent;
      btn.textContent = "Copied!";
      setTimeout(() => {
        btn.textContent = original;
      }, 1500);
    });
  });

  document
    .querySelectorAll<HTMLDivElement>(".viewport-toggle")
    .forEach((group) => {
      const target = group.dataset.target;
      const frame = document.getElementById(
        `frame-${target}`
      ) as HTMLIFrameElement | null;
      const buttons = group.querySelectorAll<HTMLButtonElement>(".viewport-btn");
      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          if (!frame) return;
          frame.style.width = btn.dataset.width ?? "100%";
          buttons.forEach((b) => b.classList.remove("bg-accent"));
          btn.classList.add("bg-accent");
        });
      });
    });
</script>
