---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ComponentPreview from "@/components/ComponentPreview.astro";

const categories = [
  {
    slug: "area",
    label: "Area",
    // The interactive variant leads as the full-width featured chart.
    demos: ["chart-area-04", "chart-area-01", "chart-area-02", "chart-area-03"],
  },
  {
    slug: "bar",
    label: "Bar",
    demos: ["chart-bar-01", "chart-bar-02", "chart-bar-03", "chart-bar-04"],
  },
  {
    slug: "line",
    label: "Line",
    demos: ["chart-line-01", "chart-line-02", "chart-line-03"],
  },
  {
    slug: "pie",
    label: "Pie",
    demos: ["chart-pie-01", "chart-pie-02", "chart-pie-03"],
  },
  {
    slug: "radar",
    label: "Radar",
    demos: ["chart-radar-01", "chart-radar-02"],
  },
  {
    slug: "radial",
    label: "Radial",
    demos: ["chart-radial-01", "chart-radial-02"],
  },
  {
    slug: "sparkline",
    label: "Sparkline",
    demos: ["chart-sparkline-01", "chart-sparkline-02", "chart-sparkline-03"],
  },
  {
    slug: "kpi",
    label: "KPI",
    demos: ["chart-kpi-01", "chart-kpi-02"],
  },
  {
    slug: "composed",
    label: "Composed",
    demos: ["chart-composed-01", "chart-composed-02"],
  },
  {
    slug: "heatmap",
    label: "Heatmap",
    demos: ["chart-heatmap-01"],
  },
];

export async function getStaticPaths() {
  return [
    { params: { category: "area" } },
    { params: { category: "bar" } },
    { params: { category: "line" } },
    { params: { category: "pie" } },
    { params: { category: "radar" } },
    { params: { category: "radial" } },
    { params: { category: "sparkline" } },
    { params: { category: "kpi" } },
    { params: { category: "composed" } },
    { params: { category: "heatmap" } },
  ];
}

const { category } = Astro.params;
const current = categories.find((c) => c.slug === category)!;
---

<BaseLayout title={`${current.label} Charts`}>
  <div class="mx-auto w-full max-w-screen-2xl px-4 py-10 sm:px-6">
    <div class="flex flex-col items-center gap-4 text-center">
      <h1 class="max-w-2xl text-balance text-3xl font-bold tracking-tighter md:text-5xl">
        Beautiful Charts &amp; Graphs
      </h1>
      <p class="max-w-xl text-balance text-muted-foreground md:text-lg">
        A collection of ready-to-use chart components built with Recharts.
        From basic charts to rich data displays, copy and paste into your apps.
      </p>
    </div>

    <div class="mt-10 flex gap-8">
      <aside class="sticky top-14 hidden h-[calc(100svh-3.5rem)] w-48 shrink-0 overflow-y-auto py-2 md:block">
        <nav class="grid gap-0.5">
          {
            categories.map((c) => (
              <a
                href={`/charts/${c.slug}`}
                class:list={[
                  "flex items-center justify-between rounded-md px-2 py-1.5 text-sm transition-colors",
                  c.slug === category
                    ? "bg-accent font-medium text-accent-foreground"
                    : "text-muted-foreground hover:text-foreground",
                ]}
              >
                {c.label}
                <span class="text-xs text-muted-foreground">{c.demos.length}</span>
              </a>
            ))
          }
        </nav>
      </aside>

      <div class="min-w-0 flex-1">
        <details class="mb-6 rounded-lg border border-border/40 md:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-between px-4 py-3 text-sm font-medium">
            {current.label} categories
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
          </summary>
          <nav class="grid gap-0.5 border-t border-border/40 px-4 py-4">
            {
              categories.map((c) => (
                <a
                  href={`/charts/${c.slug}`}
                  class:list={[
                    "flex items-center justify-between rounded-md px-2 py-1.5 text-sm transition-colors",
                    c.slug === category
                      ? "bg-accent font-medium text-accent-foreground"
                      : "text-muted-foreground hover:text-foreground",
                  ]}
                >
                  {c.label}
                  <span class="text-xs text-muted-foreground">{c.demos.length}</span>
                </a>
              ))
            }
          </nav>
        </details>

        <!-- Featured chart full-width, the rest in a responsive grid. -->
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            current.demos.map((demo, i) => (
              <div class:list={[i === 0 && "md:col-span-2 xl:col-span-3"]}>
                <ComponentPreview name={demo} wide install />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
