---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ComponentPreview from "@/components/ComponentPreview.astro";

const categories = [
  {
    slug: "area",
    label: "Area",
    demos: ["chart-area-01", "chart-area-02", "chart-area-03", "chart-area-04"],
  },
  {
    slug: "bar",
    label: "Bar",
    demos: ["chart-bar-01", "chart-bar-02", "chart-bar-03", "chart-bar-04"],
  },
  {
    slug: "line",
    label: "Line",
    demos: ["chart-line-01", "chart-line-02", "chart-line-03"],
  },
  {
    slug: "pie",
    label: "Pie",
    demos: ["chart-pie-01", "chart-pie-02", "chart-pie-03"],
  },
  {
    slug: "radar",
    label: "Radar",
    demos: ["chart-radar-01", "chart-radar-02"],
  },
  {
    slug: "radial",
    label: "Radial",
    demos: ["chart-radial-01", "chart-radial-02"],
  },
];

export async function getStaticPaths() {
  return [
    { params: { category: "area" } },
    { params: { category: "bar" } },
    { params: { category: "line" } },
    { params: { category: "pie" } },
    { params: { category: "radar" } },
    { params: { category: "radial" } },
  ];
}

const { category } = Astro.params;
const current = categories.find((c) => c.slug === category)!;
---

<BaseLayout title={`${current.label} Charts`}>
  <div class="w-full px-6 py-10">
    <h1 class="text-3xl font-bold tracking-tight">Charts</h1>
    <p class="mt-2 text-muted-foreground">
      A collection of chart components built using Recharts. Every chart is
      installable — copy the command under each preview.
    </p>

    <nav class="mt-6 flex items-center gap-1 border-b">
      {
        categories.map((c) => (
          <a
            href={`/charts/${c.slug}`}
            class:list={[
              "-mb-px border-b-2 px-3 py-2 text-sm font-medium",
              c.slug === category
                ? "border-primary text-foreground"
                : "border-transparent text-muted-foreground hover:text-foreground",
            ]}
          >
            {c.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      {
        current.demos.map((demo) => (
          <ComponentPreview name={demo} wide install />
        ))
      }
    </div>
  </div>
</BaseLayout>
