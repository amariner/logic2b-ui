---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ThemeBuilder } from "@/components/ThemeBuilder";
---

<BaseLayout
  title="Create — logic2b/ui"
  description="Pick a primary color and radius, preview the components live, and copy the generated theme CSS."
>
  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight">Create your theme</h1>
      <p class="mt-2 max-w-xl text-muted-foreground">
        Pick a primary color and radius, preview components live, then copy the
        CSS into your project. Start from the base tokens in the
        <a href="/docs/theming" class="underline underline-offset-4"
          >&nbsp;Theming</a
        > guide.
      </p>
    </div>
    <ThemeBuilder client:load />
  </main>
</BaseLayout>
