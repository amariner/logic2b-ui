---
import BaseLayout from "@/layouts/BaseLayout.astro";
import registryIndex from "../../../public/r/index.json";

const components = registryIndex.filter((item) => item.type === "registry:ui");
---

<BaseLayout title="Components — logic2b/ui">
  <main class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-bold tracking-tight">Components</h1>
    <p class="mt-2 text-muted-foreground">
      {components.length} components in the registry. Individual docs pages land in
      Phase 2.
    </p>
    <ul class="mt-8 grid gap-3">
      {
        components.map((item) => (
          <li class="rounded-lg border p-4">
            <div class="flex items-center justify-between gap-4">
              <span class="font-medium">{item.name}</span>
              <a
                href={`/r/${item.name}.json`}
                class="text-xs text-muted-foreground underline underline-offset-4 hover:text-foreground"
              >
                /r/{item.name}.json
              </a>
            </div>
            <p class="mt-1 text-sm text-muted-foreground">{item.description}</p>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
