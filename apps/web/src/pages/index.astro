---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  ComponentShowcase,
  ContributionHistory,
  AnalyticsCard,
  PowerUsage,
  NotificationsCard,
  PayoutThreshold,
} from "@/components/landing/interactive-widgets";
import {
  MilestoneForm,
  QrConnectCard,
  DistributeCard,
  ClaimableBalance,
  SavingsTargets,
  DividendList,
  ChatCard,
  AccountAccess,
  PaymentsCard,
} from "@/components/landing/static-widgets";
import {
  BuyInvestment,
  ReceivingMethod,
  RecentTransactions,
  TransferFunds,
  PreferencesCard,
  StockPerformance,
} from "@/components/create/preview-widgets";
import {
  DashboardNav,
  CardBalance,
  ConnectBank,
} from "@/components/create/preview-widgets-b";

// Monochrome chart ramp for the landing — grayscale that follows light/dark.
const monoCharts = [
  "--chart-1: color-mix(in oklch, var(--foreground) 92%, var(--background))",
  "--chart-2: color-mix(in oklch, var(--foreground) 72%, var(--background))",
  "--chart-3: color-mix(in oklch, var(--foreground) 55%, var(--background))",
  "--chart-4: color-mix(in oklch, var(--foreground) 42%, var(--background))",
  "--chart-5: color-mix(in oklch, var(--foreground) 30%, var(--background))",
].join(";");
---

<BaseLayout title="logic2b/ui — Build interfaces fast, AI-assisted">
  <main class="w-full px-4 sm:px-6">
    <section class="flex flex-col items-center gap-5 py-16 text-center md:py-24">
      <a
        href="/docs"
        class="inline-flex items-center rounded-full border bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground transition-colors hover:text-foreground"
      >
        Introducing logic2b ui v0.2 →
      </a>
      <h1
        class="max-w-3xl font-sans text-4xl font-bold leading-[1.05] tracking-tighter md:text-6xl"
      >
        The Foundation for your Design System.
      </h1>
      <p class="max-w-xl font-sans text-lg text-muted-foreground">
        A set of beautifully designed components that you copy into your project
        and make your own. Open code, works with your favorite framework, built
        for AI-assisted development.
      </p>
      <div class="flex gap-3">
        <a
          href="/create"
          class="inline-flex h-9 items-center gap-1.5 rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground shadow-xs transition-colors hover:bg-primary/90"
        >
          Build Your Own →
        </a>
        <a
          href="/docs"
          class="inline-flex h-9 items-center rounded-md border bg-background px-4 text-sm font-medium shadow-xs transition-colors hover:bg-accent"
        >
          Get Started
        </a>
      </div>
    </section>

    <!-- Bento mosaic: masonry via CSS columns. Charts are monochrome and near the
         top. On phones the columns keep a comfortable width and overflow off the
         right edge (clipped, no horizontal scroll) for a showcase "peek" look. -->
    <section class="overflow-hidden pb-24">
      <div
        style={monoCharts}
        class="w-[560px] gap-4 [column-fill:balance] columns-2 sm:w-full lg:columns-3 xl:columns-4"
      >
        <div class="mb-4 break-inside-avoid"><ComponentShowcase client:visible /></div>
        <div class="mb-4 break-inside-avoid"><AnalyticsCard client:visible /></div>
        <div class="mb-4 break-inside-avoid"><ContributionHistory client:visible /></div>
        <div class="mb-4 break-inside-avoid"><StockPerformance client:visible /></div>
        <div class="mb-4 break-inside-avoid"><PowerUsage client:visible /></div>
        <div class="mb-4 break-inside-avoid"><ClaimableBalance /></div>
        <div class="mb-4 break-inside-avoid"><SavingsTargets /></div>
        <div class="mb-4 break-inside-avoid"><MilestoneForm /></div>
        <div class="mb-4 break-inside-avoid"><QrConnectCard /></div>
        <div class="mb-4 break-inside-avoid"><NotificationsCard client:visible /></div>
        <div class="mb-4 break-inside-avoid"><DashboardNav /></div>
        <div class="mb-4 break-inside-avoid"><BuyInvestment /></div>
        <div class="mb-4 break-inside-avoid"><ChatCard /></div>
        <div class="mb-4 break-inside-avoid"><DividendList /></div>
        <div class="mb-4 break-inside-avoid"><DistributeCard /></div>
        <div class="mb-4 break-inside-avoid"><TransferFunds /></div>
        <div class="mb-4 break-inside-avoid"><AccountAccess /></div>
        <div class="mb-4 break-inside-avoid"><RecentTransactions /></div>
        <div class="mb-4 break-inside-avoid"><PayoutThreshold client:visible /></div>
        <div class="mb-4 break-inside-avoid"><PaymentsCard /></div>
        <div class="mb-4 break-inside-avoid"><PreferencesCard /></div>
        <div class="mb-4 break-inside-avoid"><ReceivingMethod /></div>
        <div class="mb-4 break-inside-avoid"><CardBalance /></div>
        <div class="mb-4 break-inside-avoid"><ConnectBank /></div>
      </div>
    </section>
  </main>

  <footer class="border-t">
    <div
      class="w-full px-6 py-8 text-center text-sm text-muted-foreground"
    >
      Built by logic2b. The source code is available on
      <a
        href="https://github.com/logic2b/ui"
        class="font-medium underline underline-offset-4 hover:text-foreground"
        >GitHub</a
      >.
    </div>
  </footer>
</BaseLayout>
