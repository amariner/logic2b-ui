{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/registry/*": ["../../packages/registry/src/*"]
    }
  },
  "include": ["src", "../../packages/registry/src"],
  "exclude": ["dist", "node_modules"]
}
