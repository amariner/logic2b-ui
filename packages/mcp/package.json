{
  "name": "@logic2b/mcp",
  "version": "0.2.0",
  "description": "MCP server that exposes the logic2b ui registry to coding agents.",
  "type": "module",
  "bin": {
    "logic2b-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "logic2b",
    "ui",
    "registry",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents"
  ],
  "homepage": "https://ui.logic2b.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amariner/logic2b-ui.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/amariner/logic2b-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "tsup"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@logic2b/tokens": "workspace:*",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
