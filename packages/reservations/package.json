{
  "name": "@logic2b/reservations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "A generic reservations/booking + payments backend (Cloudflare Worker + D1) for the logic2b storefront and booking blocks.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "db:init:local": "wrangler d1 execute logic2b-reservations --local --file=schema.sql",
    "db:init": "wrangler d1 execute logic2b-reservations --remote --file=schema.sql"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
